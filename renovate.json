{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "renovate"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "tflint/.tflint-version"
      ],
      "matchStrings": [
        "^(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "terraform-linters/tflint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
